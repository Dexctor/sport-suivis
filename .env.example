# Neon Postgres (auto-injected on Vercel via the Neon integration).
# Copy from Vercel dashboard > Storage > .env.local tab
# Either DATABASE_URL or POSTGRES_URL works.
DATABASE_URL=
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# Auth
APP_PASSWORD=change-me-to-a-strong-password
JWT_SECRET=replace-with-a-long-random-string-min-32-chars
